# ── Database ───────────────────────────────────────────────
POSTGRES_USER=macro_user
POSTGRES_PASSWORD=macro_pass
POSTGRES_DB=macro_tracker

# ── Required ───────────────────────────────────────────────
NEWS_API_KEY=your-newsapi-key-here

# ── Optional: adds YouTube video news (free 10k quota/day) ─
# Get key at: console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key-here

# ── Optional: adds ~40 more articles per ingest ────────────
# Get key at: gnews.io (free tier)
GNEWS_API_KEY=your-gnews-key-here

# ── App ────────────────────────────────────────────────────
SECRET_KEY=changeme-use-a-random-string
